# Copy to .env before running `docker compose up`.

# --- Postgres ---
POSTGRES_USER=banking
POSTGRES_PASSWORD=banking
POSTGRES_DB=banking_shield

# --- Ports exposed on the host ---
BACKEND_PORT=3000
FRONTEND_PORT=5173

# --- Secrets (rotate before any non-demo use) ---
JWT_SECRET=dev-jwt-secret-change-me
HMAC_SECRET=dev-hmac-secret-change-me
COOKIE_SECRET=dev-cookie-secret-change-me-must-be-32-chars-min

# --- Public-facing bank host ---
# Used by the Layer 5 origin check. In dev, must match the URL you open in
# the browser. In a real deployment this would be your bank's HTTPS origin.
PUBLIC_BANK_HOST=http://localhost:8080

# --- Admin (separate auth track) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# --- Host port for the unified nginx ingress ---
INGRESS_PORT=8080

# --- Allowed shield bundle SHA-256 hashes (comma-separated, lowercase hex) ---
# Populated automatically by the build pipeline in M6. Empty in M0.
ALLOWED_BUNDLE_HASHES=
